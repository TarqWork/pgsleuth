{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus (OTLP-backed)",
      "description": "A Prometheus-compatible datasource receiving OTLP from pgsleuth. Any of: Prometheus + the OTel Collector's prometheus exporter; Grafana Mimir; a vendor managed Prometheus.",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "pgsleuth reference panel — `pgsleuth.wal.io.latency` histogram on the WAL device. Drives the v0 fsync-jitter alarm (rule storage.wal.fsync.jitter).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "WAL IO latency — P50/P95/P99 (write+flush)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ns",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "P50",
          "expr": "histogram_quantile(0.5, sum by (le, op) (rate(pgsleuth_wal_io_latency_bucket{op=~\"write|write_flush\"}[1m])))",
          "legendFormat": "P50 {{op}}"
        },
        {
          "refId": "P95",
          "expr": "histogram_quantile(0.95, sum by (le, op) (rate(pgsleuth_wal_io_latency_bucket{op=~\"write|write_flush\"}[1m])))",
          "legendFormat": "P95 {{op}}"
        },
        {
          "refId": "P99",
          "expr": "histogram_quantile(0.99, sum by (le, op) (rate(pgsleuth_wal_io_latency_bucket{op=~\"write|write_flush\"}[1m])))",
          "legendFormat": "P99 {{op}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "WAL IO latency — heatmap (all ops)",
      "type": "heatmap",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 8 },
      "options": {
        "yAxis": { "unit": "ns" },
        "color": { "mode": "spectrum", "scheme": "Spectral", "steps": 64 }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (le) (rate(pgsleuth_wal_io_latency_bucket[1m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "WAL IO rate (events/s) per op",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 17 },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (op) (rate(pgsleuth_wal_io_latency_count[1m]))",
          "legendFormat": "{{op}}"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["pgsleuth", "tier1", "fsync", "ebpf"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "pgsleuth — WAL IO latency (Alarm 03)",
  "uid": "pgsleuth-wal-io-latency-v0",
  "version": 1,
  "weekStart": ""
}
